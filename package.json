{
  "name": "podcast-manager",
  "version": "1.0.0",
  "description": "Podcast Manager API - Node.js + TypeScript without frameworks",
  "main": "dist/server.js",
  "scripts": {
    "start": "node dist/server.js",
    "start:dev": "tsx watch src/server.ts",
    "build": "tsup src/server.ts --format cjs --dts",
    "lint": "tsc --noEmit"
  },
  "keywords": ["nodejs", "typescript", "podcast", "api", "rest"],
  "author": "taissocout",
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^20.11.0",
    "tsup": "^8.0.2",
    "tsx": "^4.7.0",
    "typescript": "^5.3.3"
  }
}
